{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Walmart Order Dashboard",
  "version": "0.1.0",
  "identifier": "com.order-checker.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Walmart Order Dashboard",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://tauri.localhost; img-src 'self' data: https://lh3.googleusercontent.com https://i5.walmartimages.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../client_secret.json": "./"
    },
    "windows": {
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
